---
permalink: /help/search-index.json
---
[
{% for a in site.help %}
  {
    "id": {{ forloop.index0 }},
    "url": {{ a.url | relative_url | jsonify }},
    "title": {{ a.title | jsonify }},
    "category": {{ a.category | jsonify }},
    "summary": {{ a.summary | default: "" | jsonify }},
    "body": {{ a.content | strip_html | normalize_whitespace | truncatewords: 220 | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}
]
