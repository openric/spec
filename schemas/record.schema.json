{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openric.org/schemas/v0.1.0/record.schema.json",
  "title": "OpenRiC Record response",
  "description": "Validates a single /records/{id} response emitted by an OpenRiC-conformant server. Covers rico:Record, rico:RecordSet, and rico:RecordPart.",

  "type": "object",
  "required": ["@id", "@type"],

  "properties": {
    "@context": {
      "oneOf": [
        { "type": "string", "format": "uri" },
        { "type": "object" },
        { "type": "array" }
      ]
    },

    "@id": {
      "type": "string",
      "format": "uri",
      "description": "Canonical IRI for this record."
    },

    "@type": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(rico:(Record|RecordSet|RecordPart)|https://www\\.ica\\.org/standards/RiC/ontology#(Record|RecordSet|RecordPart))$"
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(rico:(Record|RecordSet|RecordPart)|https://www\\.ica\\.org/standards/RiC/ontology#(Record|RecordSet|RecordPart))$"
          },
          "minItems": 1
        }
      ]
    },

    "rico:type":        { "type": "string" },
    "rico:identifier":  { "type": "string", "minLength": 1 },
    "rico:title":       { "$ref": "#/$defs/langString" },
    "rico:description": { "$ref": "#/$defs/langString" },
    "rico:history":     { "$ref": "#/$defs/langString" },
    "rico:arrangement": { "$ref": "#/$defs/langString" },

    "rico:hasDateRangeSet": {
      "oneOf": [
        { "$ref": "#/$defs/dateRange" },
        { "type": "array", "items": { "$ref": "#/$defs/dateRange" } }
      ]
    },

    "rico:hasExtent": {
      "oneOf": [
        { "$ref": "#/$defs/extent" },
        { "type": "array", "items": { "$ref": "#/$defs/extent" } }
      ]
    },

    "rico:hasLanguage": {
      "oneOf": [
        { "$ref": "#/$defs/language" },
        { "type": "array", "items": { "$ref": "#/$defs/language" } }
      ]
    },

    "rico:heldBy": {
      "oneOf": [
        { "$ref": "#/$defs/agentRef" },
        { "type": "array", "items": { "$ref": "#/$defs/agentRef" } }
      ]
    },

    "rico:hasCreator": {
      "oneOf": [
        { "$ref": "#/$defs/agentRef" },
        { "type": "array", "items": { "$ref": "#/$defs/agentRef" } }
      ]
    },

    "rico:hasSubject":      { "type": "array" },
    "rico:hasInstantiation": { "type": "array" },
    "rico:hasRecordPart":   { "type": "array" },
    "rico:isContainedIn":   { "oneOf": [
      { "type": "string", "format": "uri" },
      { "type": "object" }
    ] },

    "rico:conditionsOfAccess":    { "type": "string" },
    "rico:conditionsOfUse":       { "type": "string" },
    "rico:containsPersonalData":  { "type": "boolean" },
    "rico:hasSecurityClassification": { "type": "object" },
    "rico:hasAccessRestriction":   { "type": "array" }
  },

  "additionalProperties": true,

  "$defs": {
    "langString": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["@value"],
          "properties": {
            "@value":    { "type": "string" },
            "@language": { "type": "string" }
          }
        },
        {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "required": ["@value"],
                "properties": {
                  "@value":    { "type": "string" },
                  "@language": { "type": "string" }
                }
              }
            ]
          }
        }
      ]
    },

    "dateRange": {
      "type": "object",
      "anyOf": [
        { "required": ["rico:startDate"] },
        { "required": ["rico:endDate"] },
        { "required": ["rico:normalizedDate"] }
      ],
      "properties": {
        "@type":                 { "type": "string" },
        "rico:startDate":        { "$ref": "#/$defs/dateValue" },
        "rico:endDate":          { "$ref": "#/$defs/dateValue" },
        "rico:normalizedDate":   { "type": "string" },
        "rico:dateType":         { "type": "string" }
      }
    },

    "dateValue": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["@value"],
          "properties": {
            "@value": { "type": "string" },
            "@type":  { "type": "string" }
          }
        }
      ]
    },

    "extent": {
      "type": "object",
      "required": ["rico:extentType"],
      "properties": {
        "@type":           { "type": "string" },
        "rico:extentType": { "type": "string" }
      }
    },

    "language": {
      "type": "object",
      "required": ["rico:languageCode"],
      "properties": {
        "@type":            { "type": "string" },
        "rico:languageCode": {
          "type": "string",
          "pattern": "^[a-z]{2,3}(-[A-Za-z0-9]+)*$"
        }
      }
    },

    "agentRef": {
      "type": "object",
      "required": ["@type"],
      "properties": {
        "@id":       { "type": "string", "format": "uri" },
        "@type":     { "type": "string" },
        "rico:name": { "$ref": "#/$defs/langString" }
      }
    }
  }
}
