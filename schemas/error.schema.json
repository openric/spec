{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openric.org/schemas/v0.1.0/error.schema.json",
  "title": "OpenRiC Error response",
  "description": "Validates any error response emitted by an OpenRiC server. Accepts both the plain shorthand ({error: '...'}) and the full OpenRiC error envelope defined in viewing-api.md §8.",

  "oneOf": [
    {
      "title": "Plain shorthand",
      "type": "object",
      "required": ["error"],
      "properties": {
        "error":   { "type": "string" },
        "example": { "type": "string" }
      },
      "additionalProperties": true
    },
    {
      "title": "Full OpenRiC error envelope",
      "type": "object",
      "required": ["@type", "openric:status", "openric:code", "openric:message"],
      "properties": {
        "@type": {
          "type": "string",
          "const": "openric:Error"
        },
        "openric:status":  { "type": "integer", "minimum": 400, "maximum": 599 },
        "openric:code": {
          "type": "string",
          "enum": ["not-found", "forbidden", "bad-request", "rate-limited", "unavailable", "internal"]
        },
        "openric:message": { "type": "string" },
        "openric:detail":  { "type": "string" }
      },
      "additionalProperties": true
    }
  ]
}
